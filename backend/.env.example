# Copy to .env and fill in values. NEVER commit .env with real passwords.

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database: LOCAL development ---
# Use DB_* vars only. Do NOT set DATABASE_URL for normal local dev.
DB_NAME=database_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# --- Database: production / migrate against Aiven ---
# Use when running migrate or createsuperuser against the hosted DB
# (e.g. when Render Shell is unavailable). Do NOT use both DATABASE_URL
# and DB_* at the same time.
# DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require
# DB_SSL_REQUIRE=True
# DB_SSLMODE=require
#
# USE_REMOTE_DB=True
# DB_CONN_MAX_AGE=60
#
# While DEBUG=True, DATABASE_URL is ignored unless USE_REMOTE_DB=True (avoids
# exhausting Aiven connection slots). Comment out DATABASE_URL for local dev.

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Production: CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
# (defaults to CORS_ALLOWED_ORIGINS when unset)

TIME_ZONE=Asia/Manila
FRONTEND_URL=http://localhost:5173

# --- Gmail (password reset & reminders) ---
# Required for "Forgot password" to send confirmation emails to Gmail.
# 1. Enable 2-Step Verification on your Google account
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Uncomment and fill in (never commit real passwords):
# EMAIL_HOST_USER=youraccount@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=youraccount@gmail.com

# Console backend until Gmail vars above are set (auto-switches to SMTP when user+password exist)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Production HTTPS (Render terminates TLS at the edge; keep SECURE_SSL_REDIRECT=False)
# SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=31536000

# Profile pictures (Phase 1) are stored under backend/media/ — see DEPLOYMENT.md
